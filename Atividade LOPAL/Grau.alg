algoritmo "semnome"

// Autor : Caline Myrella
// Data : 13/04/2026
// Seção de Declarações 
var

   f, grau: real
inicio

      escreval ("Vamos transformar CḞ para FḞ")
      escreval ("digite o valor do grau celsius")
      leia (grau)
      
      f <- (grau * 9/5) + 32
      
      escreva ("valor final de FḞ encontrado foi", f)
      
      


fimalgoritmo
